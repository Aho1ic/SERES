# ============================================================
# 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# 服务器 API 配置
API_BASE_URL=http://10.60.73.189:9052
UPLOAD_URL=http://192.168.0.120:44333/upload

# API 认证凭证（必填）
APP_KEY_ID=your_app_key_id_here
APP_KEY_SECRET=your_app_key_secret_here

# RTMP 流配置
RTMP_SERVER=10.60.73.189
RTMP_PORT=1935

# VLLM AI 模型配置
VLLM_API_URL=http://localhost:8000/v1/chat/completions
VLLM_MODEL_NAME=Qwen3-VL-8B-Instruct
VLLM_TIMEOUT=60
VLLM_MAX_TOKENS=900

# 模型权重路径（可选，使用默认值则不需要配置）
# SPYCAM_MODEL_PATH=/path/to/spycam.pt
# PHONECALL_MODEL_PATH=/path/to/phonecall.pt
# SMOKEFIRE_MODEL_PATH=/path/to/smokefire.pt
# SOLARPANEL_MODEL_PATH=/path/to/solarpanel.pt

# 队列和并发配置
TASK_QUEUE_MAXSIZE=200
WORKER_COUNT=10
LLM_QUEUE_MAXSIZE=100
LLM_WORKER_COUNT=1
VERIFICATION_QUEUE_MAXSIZE=50
REPORT_QUEUE_MAXSIZE=200
AI_VERIFICATION_WORKERS=1
REPORT_WORKERS=1

# 检测参数配置
FRAME_INTERVAL=2
CONF_THRESHOLD=0.5
MAX_REQUESTS_PER_SECOND=1000
POLLING_INTERVAL=2

# 缓存配置
TRACK_VERIFY_CACHE_TTL=300

# 日志配置
LOG_LEVEL=INFO
